# Production Database (Recommended: PostgreSQL)
# Example: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="file:./prod.db" # Fallback to SQLite if needed, but PostgreSQL is better for production

# Security
# REPLACE THIS WITH A SECURE 64-character random string!
JWT_SECRET="generate-a-long-random-string-here"
JWT_EXPIRES_IN="7d"

# Server Config
PORT=4000
NODE_ENV="production"
FRONTEND_URL="https://your-production-frontend-domain.com"

# AI Service (Gemini)
# Get one from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# Google Auth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email Configuration (Nodemailer)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@example.com"
# SMTP_PASS="your-app-password"
