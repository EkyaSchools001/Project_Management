# Database
DATABASE_URL="postgresql://user:password@localhost:5432/schoolos"

# Server
PORT=3001
API_BASE_URL=http://localhost:3001

# JWT
JWT_SECRET=your-super-secret-key-change-in-production

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
MAX_DOCUMENT_SIZE=52428800

# Storage Type: local, aws_s3, cloudinary
STORAGE_TYPE=local

# AWS S3 Configuration (if STORAGE_TYPE=aws_s3)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name
# AWS_CDN_URL=https://cdn.yourdomain.com

# Cloudinary Configuration (if STORAGE_TYPE=cloudinary)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
# CLOUDINARY_FOLDER=schoolos

# SMTP Configuration (for email notifications)
# SMTP_HOST=smtp.ethereal.email
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password

# AI/ML Configuration
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GOOGLE_AI_API_KEY=your-google-ai-key
# AI_PROVIDER=openai  # Options: openai, anthropic, google, local
