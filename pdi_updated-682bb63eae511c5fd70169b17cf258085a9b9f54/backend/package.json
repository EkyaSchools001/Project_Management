{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec \"ts-node --transpile-only\" src/index.ts",
    "start:ai": "cd ai_service && python -m venv venv && .\\venv\\Scripts\\activate.bat && pip install -r requirements.txt && uvicorn main:app --reload --port 8001",
    "dev:all": "concurrently \"npm run dev\" \"npm run start:ai\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "npx prisma generate --schema=../database/prisma/schema.prisma && npx prisma db push --force-reset --schema=../database/prisma/schema.prisma && npx prisma db seed",
    "postinstall": "npx prisma generate --schema=../database/prisma/schema.prisma",
    "prisma:seed": "npx prisma db seed",
    "db:migrate": "npx prisma generate --schema=../database/prisma/schema.prisma && npx prisma migrate deploy --schema=../database/prisma/schema.prisma",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:backup": "npx tsx src/scripts/backupDB.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1036.0",
    "@aws-sdk/lib-storage": "^3.1036.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.3",
    "@types/nodemailer": "^7.0.11",
    "@types/socket.io": "^3.0.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.6.2",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "multer-s3": "^3.0.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "prisma": "^6.19.2",
    "rate-limit-redis": "^4.3.1",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2"
  },
  "prisma": {
    "seed": "npx ts-node --transpile-only src/seed.ts"
  }
}